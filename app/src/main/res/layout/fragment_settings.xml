<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_secondary"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/settings_title" android:textColor="@color/text_primary"
            android:textSize="22sp" android:fontFamily="sans-serif-bold"/>

        <!-- ═══ Connection Status ═══ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="20dp" android:text="@string/settings_connection"
            android:textColor="@color/primary" android:textSize="13sp"
            android:fontFamily="sans-serif-medium" android:letterSpacing="0.08"/>

        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" app:cardBackgroundColor="@color/background_primary"
            app:cardCornerRadius="16dp" app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="@string/settings_firebase_status" android:textColor="@color/text_primary" android:textSize="14sp"/>
                <TextView android:id="@+id/tvFirebaseStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:background="@drawable/bg_status_on" android:text="@string/settings_connected"
                    android:textColor="@color/status_success" android:textSize="11sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ THRESHOLD CONFIGURATION SECTION ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_threshold" android:contentDescription="thresholds"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/threshold_section_title"
                android:textColor="@color/primary" android:textSize="13sp"
                android:fontFamily="sans-serif-medium" android:letterSpacing="0.08"/>
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/threshold_section_subtitle"
            android:textColor="@color/text_tertiary" android:textSize="11sp"/>

        <!-- ── Card 1: Temperature → Ventilateur ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/background_primary"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <!-- Header row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp"
                        android:src="@drawable/ic_temperature" android:contentDescription="temp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="10dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/threshold_temp_title"
                            android:textColor="@color/text_primary" android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/threshold_temp_desc"
                            android:textColor="@color/text_tertiary" android:textSize="11sp"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvTempBadge"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:background="@drawable/bg_threshold_badge_off"
                        android:text="@string/threshold_actuator_off"
                        android:textColor="@color/text_tertiary" android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <!-- Current value -->
                <TextView android:id="@+id/tvTempCurrent"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Valeur actuelle : --"
                    android:textColor="@color/temp_start" android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"/>
                <!-- Input row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="10dp" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginEnd="6dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/threshold_high" android:textColor="@color/text_secondary"
                            android:textSize="11sp"/>
                        <EditText android:id="@+id/etTempHigh"
                            android:layout_width="match_parent" android:layout_height="42dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_threshold_input"
                            android:hint="@string/threshold_high_hint_temp"
                            android:inputType="numberDecimal"
                            android:paddingStart="12dp" android:paddingEnd="12dp"
                            android:textColor="@color/text_primary" android:textSize="14sp"
                            android:textColorHint="@color/text_tertiary"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="6dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/threshold_low" android:textColor="@color/text_secondary"
                            android:textSize="11sp"/>
                        <EditText android:id="@+id/etTempLow"
                            android:layout_width="match_parent" android:layout_height="42dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_threshold_input"
                            android:hint="@string/threshold_low_hint_temp"
                            android:inputType="numberDecimal"
                            android:paddingStart="12dp" android:paddingEnd="12dp"
                            android:textColor="@color/text_primary" android:textSize="14sp"
                            android:textColorHint="@color/text_tertiary"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Card 2: Luminosité → Lampe ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@color/background_primary"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp"
                        android:src="@drawable/ic_light" android:contentDescription="light"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="10dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/threshold_lux_title"
                            android:textColor="@color/text_primary" android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/threshold_lux_desc"
                            android:textColor="@color/text_tertiary" android:textSize="11sp"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvLuxBadge"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:background="@drawable/bg_threshold_badge_off"
                        android:text="@string/threshold_actuator_off"
                        android:textColor="@color/text_tertiary" android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <TextView android:id="@+id/tvLuxCurrent"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Valeur actuelle : --"
                    android:textColor="@color/light_start" android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="10dp" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginEnd="6dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/threshold_high" android:textColor="@color/text_secondary"
                            android:textSize="11sp"/>
                        <EditText android:id="@+id/etLuxHigh"
                            android:layout_width="match_parent" android:layout_height="42dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_threshold_input"
                            android:hint="@string/threshold_high_hint_lux"
                            android:inputType="numberDecimal"
                            android:paddingStart="12dp" android:paddingEnd="12dp"
                            android:textColor="@color/text_primary" android:textSize="14sp"
                            android:textColorHint="@color/text_tertiary"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="6dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/threshold_low" android:textColor="@color/text_secondary"
                            android:textSize="11sp"/>
                        <EditText android:id="@+id/etLuxLow"
                            android:layout_width="match_parent" android:layout_height="42dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_threshold_input"
                            android:hint="@string/threshold_low_hint_lux"
                            android:inputType="numberDecimal"
                            android:paddingStart="12dp" android:paddingEnd="12dp"
                            android:textColor="@color/text_primary" android:textSize="14sp"
                            android:textColorHint="@color/text_tertiary"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Card 3: Humidité Sol → Vanne ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@color/background_primary"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp"
                        android:src="@drawable/ic_humidity" android:contentDescription="soil"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="10dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/threshold_soil_title"
                            android:textColor="@color/text_primary" android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/threshold_soil_desc"
                            android:textColor="@color/text_tertiary" android:textSize="11sp"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvSoilBadge"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:background="@drawable/bg_threshold_badge_off"
                        android:text="@string/threshold_actuator_off"
                        android:textColor="@color/text_tertiary" android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <TextView android:id="@+id/tvSoilCurrent"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Valeur actuelle : --"
                    android:textColor="@color/humidity_start" android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="10dp" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginEnd="6dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/threshold_high" android:textColor="@color/text_secondary"
                            android:textSize="11sp"/>
                        <EditText android:id="@+id/etSoilHigh"
                            android:layout_width="match_parent" android:layout_height="42dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_threshold_input"
                            android:hint="@string/threshold_high_hint_soil"
                            android:inputType="numberDecimal"
                            android:paddingStart="12dp" android:paddingEnd="12dp"
                            android:textColor="@color/text_primary" android:textSize="14sp"
                            android:textColorHint="@color/text_tertiary"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="6dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/threshold_low" android:textColor="@color/text_secondary"
                            android:textSize="11sp"/>
                        <EditText android:id="@+id/etSoilLow"
                            android:layout_width="match_parent" android:layout_height="42dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_threshold_input"
                            android:hint="@string/threshold_low_hint_soil"
                            android:inputType="numberDecimal"
                            android:paddingStart="12dp" android:paddingEnd="12dp"
                            android:textColor="@color/text_primary" android:textSize="14sp"
                            android:textColorHint="@color/text_tertiary"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ Apply Button ═══ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApplyThresholds"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:text="@string/threshold_apply"
            android:textColor="@color/text_on_primary"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="@color/primary"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_threshold"
            app:iconGravity="textStart"
            app:iconTint="@color/white"/>

        <!-- ═══ Device Info ═══ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="24dp" android:text="@string/settings_device_info"
            android:textColor="@color/primary" android:textSize="13sp"
            android:fontFamily="sans-serif-medium" android:letterSpacing="0.08"/>

        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" app:cardBackgroundColor="@color/background_primary"
            app:cardCornerRadius="16dp" app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/settings_device_name" android:textColor="@color/text_primary" android:textSize="14sp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:text="@string/settings_version"
                    android:textColor="@color/text_tertiary" android:textSize="12sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ Lock Log ═══ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="20dp" android:text="@string/settings_lock_log"
            android:textColor="@color/primary" android:textSize="13sp"
            android:fontFamily="sans-serif-medium" android:letterSpacing="0.08"/>

        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" app:cardBackgroundColor="@color/background_primary"
            app:cardCornerRadius="16dp" app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:id="@+id/tvLastAccess" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="--"
                    android:textColor="@color/text_primary" android:textSize="14sp"/>
                <TextView android:id="@+id/tvAccessFailed" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_marginTop="4dp"
                    android:visibility="gone" android:text="⚠ Tentative échouée détectée"
                    android:textColor="@color/status_danger" android:textSize="12sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ Logout ═══ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="16dp"
            android:text="@string/settings_logout"
            android:textColor="@color/status_danger"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:backgroundTint="@color/status_danger_light"
            app:cornerRadius="16dp"
            app:strokeColor="@color/status_danger"
            app:strokeWidth="1dp"/>
    </LinearLayout>
</ScrollView>
