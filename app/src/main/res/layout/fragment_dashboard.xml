<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_secondary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp">

            <!-- Header with logo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_greeting"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-bold"/>
                    <TextView
                        android:id="@+id/tvDashSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/dashboard_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/logo_agri_smart"
                    android:scaleType="fitCenter"
                    android:contentDescription="Logo"/>
            </LinearLayout>

            <!-- Last update -->
            <TextView
                android:id="@+id/tvLastUpdate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp"/>

            <!-- Section: Sensors -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/dashboard_sensors"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"/>

            <!-- Sensor Grid: Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <!-- Temperature -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_sensor_temp"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:gravity="center">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_temperature" android:contentDescription="temp"/>
                        <TextView
                            android:id="@+id/tvTempValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="--"
                            android:textColor="@color/white"
                            android:textSize="28sp"
                            android:fontFamily="sans-serif-bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sensor_temperature"
                            android:textColor="#CCFFFFFF"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Humidity -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_sensor_humidity"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:gravity="center">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_humidity" android:contentDescription="hum"/>
                        <TextView
                            android:id="@+id/tvHumValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="--"
                            android:textColor="@color/white"
                            android:textSize="28sp"
                            android:fontFamily="sans-serif-bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sensor_humidity"
                            android:textColor="#CCFFFFFF"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Sensor Grid: Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <!-- Pressure -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_sensor_pressure"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:gravity="center">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_pressure" android:contentDescription="press"/>
                        <TextView
                            android:id="@+id/tvPressValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="--"
                            android:textColor="@color/white"
                            android:textSize="28sp"
                            android:fontFamily="sans-serif-bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sensor_pressure"
                            android:textColor="#CCFFFFFF"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Light -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_sensor_light"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:gravity="center">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@drawable/ic_light" android:contentDescription="light"/>
                        <TextView
                            android:id="@+id/tvLightValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="--"
                            android:textColor="@color/white"
                            android:textSize="28sp"
                            android:fontFamily="sans-serif-bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sensor_light"
                            android:textColor="#CCFFFFFF"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Sensor Grid: Row 3 - Soil Humidity (full width) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_sensor_soil"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_humidity" android:contentDescription="soil"
                        android:layout_marginEnd="16dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvSoilValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/white"
                            android:textSize="32sp"
                            android:fontFamily="sans-serif-bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sensor_soil_humidity"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section: Actuators Status -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/dashboard_actuators_status"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/background_primary"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_lock" android:contentDescription="lock"/>
                        <TextView android:id="@+id/tvLockStatus"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="4dp" android:text="@string/state_off"
                            android:textSize="10sp" android:textColor="@color/status_danger"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_lamp" android:contentDescription="lamp"/>
                        <TextView android:id="@+id/tvLampStatus"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="4dp" android:text="@string/state_off"
                            android:textSize="10sp" android:textColor="@color/status_danger"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_fan" android:contentDescription="fan"/>
                        <TextView android:id="@+id/tvFanStatus"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="4dp" android:text="@string/state_off"
                            android:textSize="10sp" android:textColor="@color/status_danger"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_valve" android:contentDescription="valve"/>
                        <TextView android:id="@+id/tvValveStatus"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="4dp" android:text="@string/state_off"
                            android:textSize="10sp" android:textColor="@color/status_danger"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
