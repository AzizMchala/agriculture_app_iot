<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Splash Theme -->
    <style name="Theme.Agri_app.Splash" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/background_primary</item>
        <item name="android:statusBarColor">@color/background_primary</item>
        <item name="android:navigationBarColor">@color/background_primary</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Base application theme: LIGHT -->
    <style name="Base.Theme.Agri_app" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/secondary</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="android:windowBackground">@color/background_primary</item>
        <item name="android:statusBarColor">@color/background_primary</item>
        <item name="android:navigationBarColor">@color/nav_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="Theme.Agri_app" parent="Base.Theme.Agri_app" />

    <!-- Card Style -->
    <style name="Widget.Agri.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">2dp</item>
    </style>

    <!-- Button Primary -->
    <style name="Widget.Agri.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="cornerRadius">@dimen/radius_xl</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_lg</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Text Input -->
    <style name="Widget.Agri.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_md</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="Widget.Agri.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/nav_background</item>
        <item name="itemIconTint">@color/bottom_nav_colors</item>
        <item name="itemTextColor">@color/bottom_nav_colors</item>
    </style>

    <style name="Widget.Agri.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/nav_indicator</item>
    </style>

    <!-- Switch -->
    <style name="Widget.Agri.Switch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="thumbTint">@color/switch_thumb_colors</item>
        <item name="trackTint">@color/switch_track_colors</item>
    </style>

    <!-- Tab Layout -->
    <style name="Widget.Agri.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/primary</item>
        <item name="tabSelectedTextColor">@color/primary</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabBackground">@color/transparent</item>
    </style>

    <!-- Bottom Nav Text Styles -->
    <style name="Widget.Agri.BottomNav.TextActive" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.Agri.BottomNav.TextInactive" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_tertiary</item>
    </style>

    <style name="Widget.Agri.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary_surface</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Agri.BottomNav.Indicator</item>
    </style>

    <style name="ShapeAppearance.Agri.BottomNav.Indicator" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">12dp</item>
    </style>
</resources>